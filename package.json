{
  "name": "budget-desk",
  "private": true,
  "version": "0.1.0",
  "description": "A local-first monthly budgeting desktop app.",
  "author": "Nathan",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "desktop": "npm run build && electron .",
    "desktop:dir": "npm run build && electron-builder --dir",
    "desktop:installer": "npm run build && electron-builder --win nsis"
  },
  "dependencies": {
    "@mantine/charts": "^9.1.1",
    "@mantine/core": "^9.1.1",
    "@mantine/dates": "^9.1.1",
    "@mantine/hooks": "^9.1.1",
    "@mantine/notifications": "^9.1.1",
    "dayjs": "^1.11.20",
    "lucide-react": "^0.468.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.5.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.10"
  },
  "build": {
    "appId": "com.nathan.budgetdesk",
    "productName": "Budget Desk",
    "directories": {
      "output": "release"
    },
    "npmRebuild": false,
    "extraMetadata": {
      "dependencies": {}
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "!node_modules/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "signAndEditExecutable": false,
      "artifactName": "${productName}-${version}-${arch}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
